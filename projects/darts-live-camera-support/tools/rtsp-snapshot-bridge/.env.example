RTSP_URL=rtsp://camera_user:camera_password@192.168.1.50:554/stream2
PORT=8089
# Restricts which browser origin may fetch GET /snapshot (CORS). Defaults to
# http://localhost:3000 (the app's local dev origin) if not set.
ALLOWED_ORIGIN=http://localhost:3000
# Bind address for the bridge's HTTP server. Defaults to 127.0.0.1
# (localhost-only), since the pilot setup runs the bridge on the same machine
# as the Next.js app. Only set this to 0.0.0.0 if the app and bridge run on
# two separate devices on the same local network - this exposes /snapshot
# (and therefore the camera feed) to that whole network, so opt in deliberately.
BRIDGE_HOST=127.0.0.1
